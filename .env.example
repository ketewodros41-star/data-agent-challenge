# Oracle Forge — Environment Variables

# ── LLM API keys ─────────────────────────────────────────────────────────────

# OpenRouter key (used by the injection test suite and optionally by the agent)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_key_here

# Anthropic key (if calling Claude directly instead of via OpenRouter)
ANTHROPIC_API_KEY=your_key_here

# ── Cloudflare Workers sandbox ────────────────────────────────────────────────

# URL of the deployed sandbox worker.
# After running `cd workers/sandbox && wrangler deploy`, Cloudflare prints this URL.
# Format: https://oracle-forge-sandbox.<your-subdomain>.workers.dev
SANDBOX_URL=https://data-agent-challenge-sandbox.mdwithgod.workers.dev
# ── Database connections ──────────────────────────────────────────────────────

# PostgreSQL (primary — most DAB queries use this)
POSTGRES_URL=postgresql://user:password@host:5432/dbname

# MongoDB
MONGODB_URL=mongodb://user:password@host:27017/dbname

# SQLite (local file path)
SQLITE_PATH=/path/to/your/database.db

# DuckDB (local file path, or :memory: for in-memory)
DUCKDB_PATH=/path/to/your/database.duckdb

# ── MCP Toolbox ───────────────────────────────────────────────────────────────

# Base URL of the running MCP Toolbox server (default port 5000)
MCP_TOOLBOX_URL=http://localhost:5000
